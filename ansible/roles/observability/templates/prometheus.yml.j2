global:
  scrape_interval: 15s
  external_labels:
    node: "{{ node_name }}"
    host: "{{ ansible_host }}"

scrape_configs:
  - job_name: "{{ node_name }}"
    static_configs:
      - targets: ["localhost:{{ obs_metrics_port }}"]
        labels:
          client: "{{ node_name }}"

  - job_name: "cadvisor"
    static_configs:
      - targets: ["localhost:{{ cadvisor_port }}"]

  - job_name: "node_exporter"
    static_configs:
      - targets: ["localhost:{{ node_exporter_port }}"]

  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]

remote_write:
  - url: "{{ remote_write_url }}"
